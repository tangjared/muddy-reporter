# --- LLM keys (at least one is recommended) ----------------------------------

# Free tier: https://aistudio.google.com/apikey  (preferred — large context, free)
GEMINI_API_KEY=

# Default is "gemini-2.5-flash" (works on free tier).
# gemini-2.5-pro is paid-only as of 2025; using it on a free key returns 429.
# Override with a paid model only if your key is on a billing-enabled project.
# GEMINI_MODEL=gemini-2.5-flash

# Optional fallback provider:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# Force a specific provider (gemini | openai | heuristic). Leave blank for auto.
# LLM_PROVIDER=

# --- SEC EDGAR ---------------------------------------------------------------
# Required by SEC's automated-access policy. Use your real name & email.
SEC_USER_AGENT=Your Name your.email@example.com
